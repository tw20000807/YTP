{
  "name": "cpp-debugger",
  "displayName": "C++ Debug Visualizer",
  "description": "Fetch and show debug variables from C++ programs for competitive programming",
  "version": "0.4.0",
  "publisher": "brinton",
  "repository": {
    "type": "git",
    "url": "https://github.com/tw20000807/YTP"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Debuggers"
  ],
  "activationEvents": [
    "onDebug"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ytp.printDebugVariables",
        "title": "YTP: Print Debug Variables"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.x",
    "@typescript-eslint/parser": "^6.x",
    "eslint": "^8.x",
    "typescript": "^5.3.0"
  }
}
